# Groq API key — powers all LLM calls (get one at https://console.groq.com/keys)
GROQ_API_KEY=your-groq-api-key

# Tavily API key — used by the symptom checker's web-search MCP tool (https://app.tavily.com/)
TAVILY_API_KEY=your-tavily-api-key

# Optional model overrides
# GROQ_MODEL=llama-3.3-70b-versatile        # reasoning nodes (routing, info, symptom triage)
# GROQ_SQL_MODEL=llama-3.1-8b-instant       # SQL tool agent (more reliable at tool calling)
